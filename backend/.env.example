APP_NAME=RecallStack
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
BACKEND_PORT=8000

DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/recallstack
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800

REDIS_URL=rediss://default:YOUR_UPSTASH_TOKEN@YOUR-ENDPOINT.upstash.io:6379

PINECONE_API_KEY=pcsk_xxxxxxxx
PINECONE_INDEX_NAME=recallstack-prod
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_cloudinary_secret

CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev
CLERK_SECRET_KEY=

GROQ_API_KEY=gsk_xxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxx

ACTIVE_LLM_PROVIDER=groq
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_MODEL=gemini-1.5-flash

EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_BATCH_SIZE=32

RETRIEVAL_DEFAULT_TOP_K=8
RETRIEVAL_MAX_TOP_K=50
RETRIEVAL_MIN_SIMILARITY=0.20

RAG_MAX_CHUNKS=6
RAG_MAX_CONTEXT_CHARS=12000
LLM_TIMEOUT_SECONDS=60

CHAT_HISTORY_MAX_MESSAGES=12
CHAT_HISTORY_MAX_CHARS=8000

REDIS_STREAM_TTL_SECONDS=900
CHAT_STREAM_MAX_DURATION_SECONDS=180

INGESTION_MAX_RETRIES=5
INGESTION_RETRY_BACKOFF_SECONDS=10

CELERY_LOG_LEVEL=info
CELERY_CONCURRENCY=2
CELERY_QUEUES=recallstack_default

CLERK_WEBHOOK_SIGNING_KEY=whsec_your_clerk_webhook_signing_key_here

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_CHAT_MESSAGE=60
RATE_LIMIT_CHAT_STREAM=30
RATE_LIMIT_RAG_ASK=60
RATE_LIMIT_DOCUMENTS_UPLOAD=20
RATE_LIMIT_EVALUATION_RUN=10
RATE_LIMIT_BENCHMARK_RUN=5

TEST_JWT_SECRET=
TEST_DATABASE_URL=
